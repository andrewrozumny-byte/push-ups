# Vercel Postgres (или Neon после миграции)
# Получить в Vercel Dashboard → Storage → Postgres
POSTGRES_URL="postgres://..."

# Пароль для входа в админку (/admin)
ADMIN_PASSWORD="your-secret-password"

# Секрет для Vercel Cron (берётся из Authorization: Bearer CRON_SECRET)
CRON_SECRET="your-cron-secret"

# Telegram bot для сповіщень
TELEGRAM_BOT_TOKEN="123456:ABCDEF_your_bot_token"
TELEGRAM_CHAT_ID="@your_group_or_chat_id"

# Дата старта (норма отжиманий растёт +1 каждый день)
NEXT_PUBLIC_START_DATE="2025-01-20"

# Публичный URL приложения (для генерации ссылок в /admin)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
